# --- Data / Outputs (keep structure, ignore generated content) ---
# Raw inputs are sample data, keep them.
# Processed and output files are reproducible from run_pipeline.py.
data/processed/**/*.csv
data/output/**/*.csv
data/output/**/*.docx
data/output/**/*.html
data/output/**/*.txt
!data/output/accuracy_log.csv
!data/**/.gitkeep

# --- Reports ---
reports/
*.docx
!docs/*.docx

# --- Logs ---
*.log
logs/

# --- Packaged output ---
dist-package/
*.zip
*.tar.gz

# --- Keep trained demo models ---
# .pkl normally ignored, but we keep the seeded demo models to make first-run reproducible.
# If you want to exclude them, uncomment the next line:
# models/**/*.pkl

